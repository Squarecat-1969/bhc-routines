# Copy to .env for local runs. NEVER commit .env — it is gitignored.
# In CI these are GitHub Actions repository secrets, not a file.

# --- Required for every pass and the combined orchestrator -------------------

# Bearer token for the Aida Google Sheets proxy (https://aida.hougham.us/api/brain/sheets).
# The Google service-account key itself lives in Vercel, not here.
BRAIN_API_TOKEN=

# Attio REST API key. Needs read on People + Lists, and write on People
# (PASS 4 writes only the three cadence attributes; PASS 4.5 writes only cache fields).
ATTIO_API_KEY=

# Needed for PASS 2's enrichment call and PASS 2.5's task-reconciliation call.
# Required by the combined orchestrator (it throws at startup without it, even
# in --dry-run, since PASS 2/2.5 both need it). Named deliberately unique (not
# just ANTHROPIC_API_KEY) to avoid colliding with whatever key is already in
# use elsewhere.
ANTHROPIC_BHC_ROUTINES_API=

# --- Optional ----------------------------------------------------------------

# Slack incoming-webhook URL for #aida — PASS 3's digest, PASS 4/4.5's
# addenda. If unset, every pass computes and writes as normal but skips the
# Slack post (falls back to a no-op poster that logs what would have posted).
SLACK_WEBHOOK_URL=

# --- Overrides (all have working defaults; leave blank unless you mean it) ----

# IANA timezone used to resolve "today" for cadence math. See docs/pass4-notes.md
# — this is a deliberate, reviewable choice, not a cosmetic setting. Bobby decided
# UTC on 2026-07-17, to match PASS 4.5's convention (both passes now agree on TODAY).
RUN_TIMEZONE=UTC

SHEETS_PROXY_URL=https://aida.hougham.us/api/brain/sheets
ATTIO_API_BASE=https://api.attio.com/v2
