# Copy to .env for local runs. NEVER commit .env — it is gitignored.
# In CI these are GitHub Actions repository secrets, not a file.

# --- Required for PASS 4 -----------------------------------------------------

# Bearer token for the Aida Google Sheets proxy (https://aida.hougham.us/api/brain/sheets).
# The Google service-account key itself lives in Vercel, not here.
BRAIN_API_TOKEN=

# Attio REST API key. Needs read on People + Lists, and write on People
# (only the three cadence attributes are ever written by PASS 4).
ATTIO_API_KEY=

# --- Optional ----------------------------------------------------------------

# Slack incoming-webhook URL for the #aida cadence addendum (PASS 4f).
# If unset, PASS 4 computes and writes as normal but skips the Slack post.
SLACK_WEBHOOK_URL=

# Only needed once PASS 2's narrow LLM calls land (step 5). Unused by PASS 4.
ANTHROPIC_API_KEY=

# --- Overrides (all have working defaults; leave blank unless you mean it) ----

# IANA timezone used to resolve "today" for cadence math. See docs/pass4-notes.md
# — this is a deliberate, reviewable choice, not a cosmetic setting.
RUN_TIMEZONE=America/Los_Angeles

SHEETS_PROXY_URL=https://aida.hougham.us/api/brain/sheets
ATTIO_API_BASE=https://api.attio.com/v2
